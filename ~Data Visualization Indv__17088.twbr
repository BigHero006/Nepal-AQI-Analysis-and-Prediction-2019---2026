      <aliases enabled='yes' />
      <column datatype='integer' name='[AQI]' role='measure' type='quantitative' />
      <column caption='Avg Hourly Traffic Vol' datatype='integer' name='[Avg_Hourly_Traffic_Vol]' role='measure' type='quantitative' />
      <column caption='Avg Treatment Cost NPR (Health and Emissions.csv1)' datatype='integer' name='[Avg_Treatment_Cost_NPR (Health_and_Emissions.csv1)]' role='measure' type='quantitative' />
      <column caption='Avg Treatment Cost NPR' datatype='integer' name='[Avg_Treatment_Cost_NPR]' role='measure' type='quantitative' />
      <column caption='CO2 Equivalent Mt' datatype='real' name='[CO2_Equivalent_Mt]' role='measure' type='quantitative' />
      <column caption='AQI Rank' datatype='real' name='[Calculation_0241115058774016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [AvgAQI] &gt; [Top 66% threshold] THEN 3&#13;&#10;ELSEIF [Avg. AQI] &gt; [Top 33% threshold] THEN 2&#13;&#10;ELSE 1 END' />
      </column>
      <column caption='Metric To Display' datatype='real' name='[Calculation_1087738859941888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &quot;AQI&quot; THEN [AQI]&#13;&#10;  WHEN &quot;PM2.5&quot; THEN [PM2_5]&#13;&#10;  WHEN &quot;PM10&quot; THEN [PM10]&#13;&#10;END' />
