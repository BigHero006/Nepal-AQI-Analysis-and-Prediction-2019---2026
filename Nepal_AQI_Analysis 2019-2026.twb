      </column>
      <column caption='AQI Risk Category' datatype='string' name='[Calculation_0368933698740224]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([AQI]) &lt;= 50 THEN &quot;1 - Good&quot;&#13;&#10;ELSEIF AVG([AQI]) &lt;= 100 THEN &quot;2 - Moderate&quot;&#13;&#10;ELSEIF AVG([AQI]) &lt;= 150 THEN &quot;3 - Unhealthy for Sensitive Groups&quot;&#13;&#10;ELSEIF AVG([AQI]) &lt;= 200 THEN &quot;4 - Unhealthy&quot;&#13;&#10;ELSEIF AVG([AQI]) &lt;= 300 THEN &quot;5 - Very Unhealthy&quot;&#13;&#10;ELSE &quot;6 - Hazardous&quot;&#13;&#10;END' />
      </column>
      <column caption='Cases per 10K people' datatype='real' name='[Calculation_0368933699682305]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Respiratory_Cases (Health_and_Emissions.csv1)]) / SUM([Pop])) * 10000' />
      </column>
      <column caption='Trend Status' datatype='string' name='[Calculation_0368933701046274]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation1] &gt; 0 THEN &quot;Worsening (Increased AQI)&quot;&#13;&#10;ELSE &quot;Improving (Decreased AQI)&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Hospitalization  % Rate ' datatype='real' name='[Calculation_0368933702803459]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Hospital_Admissions (Health_and_Emissions.csv1)]) / SUM([Respiratory_Cases (Health_and_Emissions.csv1)])' />
      </column>
      <column caption='Pm 2.5 Danger level' datatype='string' name='[Calculation_0368933703303172]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [PM2_5] &gt;= 150 THEN &quot;Hazardous Event&quot;&#13;&#10;ELSE &quot;Below Hazardous Threshold&quot;&#13;&#10;END' />
      </column>
      <column caption='Metric To Display' datatype='real' name='[Calculation_1087738859941888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &quot;AQI&quot; THEN [AQI]&#13;&#10;  WHEN &quot;PM2.5&quot; THEN [PM2_5]&#13;&#10;  WHEN &quot;PM10&quot; THEN [PM10]&#13;&#10;END' />
      </column>
      <column caption='AQI Color Logic' datatype='string' name='[Calculation_1087738862907394]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [AQI] &lt;= 50 THEN &quot;Good&quot;&#13;&#10;ELSEIF [AQI] &lt;= 100 THEN &quot;Moderate&quot;&#13;&#10;ELSEIF [AQI] &lt;= 150 THEN &quot;Unhealthy&quot;&#13;&#10;ELSE &quot;Hazardous&quot;&#13;&#10;END' />
      </column>
      <column caption='Differences' datatype='integer' name='[Calculation_1204562305953797]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Respiratory_Cases (Health_and_Emissions.csv1)] - [Hospital_Admissions (Health_and_Emissions.csv1)]' />
      </column>
